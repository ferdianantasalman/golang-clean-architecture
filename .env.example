APP_NAME=golang-clean-architecture
WEB_PORT=3000
WEB_PREFORK=false
LOG_LEVEL=6

DB_NAME=golang-app
DB_USER=golang
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root

DB_NAME=golang-clean-architecture
DB_POOL_IDLE=10
DB_POOL_MAX=100
DB_POOL_LIFETIME=300
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

RATE_LIMIT_MAX_REQUEST=100
RATE_LIMIT_DURATION_SEC=1

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

JWT_SECRET=change_this_to_a_random_secret
JWT_ACCESS_EXPIRY_MIN=15
JWT_REFRESH_EXPIRY_HOUR=168

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=golang-clean-architecture
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_PRODUCER_ENABLED=false
